# Beat81 Bot Environment Variables
# Copy this file to .env and fill in your values

# Your Beat81 API bearer token (from browser DevTools when logged in)
BEARER_TOKEN=your_bearer_token_here

# Your Beat81 user ID (found in API requests when logged in)
USER_ID=a8927521-568e-43a7-ba33-d18b6596964e

# Sendling location ID (will be auto-detected if left empty, or set manually)
LOCATION_ID_SENDLING=

# Email configuration for notifications
EMAIL_RECIPIENT=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password